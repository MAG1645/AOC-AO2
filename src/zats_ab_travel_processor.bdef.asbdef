projection;
strict ( 2 );

define behavior for ZATS_AB_TRAVEL_PROCESSOR alias Travel
{
  use create;
  use update;
  use delete;

  use association _Booking { create; }
}

define behavior for ZATS_AB_BOOKING_PROCESSOR alias Booking
{
  use update;
  use delete;

  use association _Travel;
  use association _BookingSuppl { create; }
}

define behavior for ZATS_AB_BOOKSUPPL_PROCESSOR alias BookSuppl
{
  use update;
  use delete;

  use association _Travel;
  use association _Booking;
}